{"type":"tool_use","timestamp":"2026-04-27T02:20:53.180Z","tool_name":"write_file","tool_id":"write_file_1777256453180_0","parameters":{"content":"import numpy as np\nimport os\nimport glob\n\ndef summarize_cka():\n    files = glob.glob('results/*_cka.npy')\n    results = {}\n    \n    for f in files:\n        name = os.path.basename(f).replace('_cka.npy', '')\n        cka = np.load(f)\n        \n        # Adjacent CKA\n        adj = [cka[i, i+1] for i in range(len(cka)-1)]\n        \n        # Mean similarity between first and last layer\n        first_last = cka[0, -1]\n        \n        results[name] = {\n            'mean_adj': np.mean(adj),\n            'min_adj': np.min(adj),\n            'max_adj': np.max(adj),\n            'first_last': first_last,\n            'adj_values': adj\n        }\n        \n    # Print summary\n    print(f\"{'Model Name':<50} | {'Mean Adj':<10} | {'First-Last':<10}\")\n    print(\"-\" * 75)\n    for name, res in sorted(results.items()):\n        print(f\"{name:<50} | {res['mean_adj']:<10.4f} | {res['first_last']:<10.4f}\")\n\n    # Specific Comparison: Random vs Trained (MNIST h512)\n    print(\"\\nComparison: Random vs Trained (MNIST h512)\")\n    r_name = \"mnist_h512_l10_relu_s42_random\"\n    t_name = \"mnist_h512_l10_relu_s42_trained\"\n    if r_name in results and t_name in results:\n        print(f\"Random Mean Adj: {results[r_name]['mean_adj']:.4f}\")\n        print(f\"Trained Mean Adj: {results[t_name]['mean_adj']:.4f}\")\n        print(f\"Random First-Last: {results[r_name]['first_last']:.4f}\")\n        print(f\"Trained First-Last: {results[t_name]['first_last']:.4f}\")\n\n    # Specific Comparison: Width (MNIST)\n    print(\"\\nComparison: Width (MNIST Trained)\")\n    for w in [128, 512, 1024]:\n        name = f\"mnist_h{w}_l10_relu_s42_trained\"\n        if name in results:\n            print(f\"Width {w:4d}: Mean Adj={results[name]['mean_adj']:.4f}, First-Last={results[name]['first_last']:.4f}\")\n\nif __name__ == \"__main__\":\n    summarize_cka()\n","file_path":"src/summary.py"}}
